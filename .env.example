# ═══════════════════════════════════════════════════════════
# NutriMaster Pipeline - 环境变量配置模板
# ═══════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# .env 文件已在 .gitignore 中，不会被上传到 GitHub
# ═══════════════════════════════════════════════════════════

# 主 API
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.gpugeek.com/v1
MODEL=Vendor2/Claude-4.6-opus

# Fallback API（OpenRouter - 当主 API 不可用时自动切换）
FALLBACK_API_KEY=your-fallback-key-here
FALLBACK_BASE_URL=https://openrouter.ai/api/v1
FALLBACK_MODEL=openai/gpt-5.4

# ═══════════════════════════════════════════════════════════
# Supabase（Web 标注平台数据导入用）
# ═══════════════════════════════════════════════════════════
# 在 Supabase Dashboard → Settings → API 中获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ═══════════════════════════════════════════════════════════
# Vercel 前端环境变量（需要在 Vercel Dashboard 里手动添加）
# ═══════════════════════════════════════════════════════════
# 前端只需要这两个，不需要 API Key 和 SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
