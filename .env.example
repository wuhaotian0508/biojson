# ═══════════════════════════════════════════════════════════
# NutriMaster Pipeline - 环境变量配置模板
# ═══════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# .env 文件已在 .gitignore 中，不会被上传到 GitHub
# ═══════════════════════════════════════════════════════════

# LLM API
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=http://43.159.131.233:3001/v1
MAIN_MODEL=deepseek-v4-flash
EXTRACTOR_MODEL=gpt-5.5

# ═══════════════════════════════════════════════════════════
# Supabase（Web 标注平台数据导入用）
# ═══════════════════════════════════════════════════════════
# 在 Supabase Dashboard → Settings → API 中获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ═══════════════════════════════════════════════════════════
# Vercel 前端环境变量（需要在 Vercel Dashboard 里手动添加）
# ═══════════════════════════════════════════════════════════
# 前端只需要这两个，不需要 API Key 和 SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
