   "source": [
    "# ── 模拟调用 resolve_test_files ──────────────────────────\n",
    "import os\n",
    "\n",
    "def resolve_test_files(files):\n",
    "    test_index = os.getenv(\"TEST_INDEX\", \"1\")\n",
    "    if test_index.isdigit():\n",
    "        idx = int(test_index) - 1\n",
    "        if 0 <= idx < len(files):\n",
    "            print(f\"  🧪 按编号: 第 {idx+1} 个 → {files[idx]}\")\n",
    "            return [files[idx]]\n",
    "        else:\n",
    "            print(f\"  ❌ 编号 {idx+1} 超出范围\")\n",
    "            return []\n",
    "    target = test_index if test_index.endswith(\".md\") else test_index + \".md\"\n",
    "    matched = [f for f in files if f == target]\n",
    "    if matched:\n",
    "        print(f\"  🧪 精确匹配 → {matched[0]}\")\n",
    "        return matched\n",
    "    matched = [f for f in files if test_index in f]\n",
    "    if matched:\n",
    "        print(f\"  🧪 模糊匹配 → {matched[0]}\")\n",
    "        return [matched[0]]\n",
    "    print(f\"  ❌ 未找到 '{test_index}'\")\n",
    "    return []\n",
    "\n",
    "files = [\n",
    "    \"MinerU_markdown_mmc3_2031567019886178304.md\",\n",
    "    \"MinerU_markdown_mmc10_2031567061837611008.md\",\n",
    "    \"new.md\",\n",
    "]\n",
    "\n",
    "# 场景1: 编号\n",
    "os.environ[\"TEST_INDEX\"] = \"2\"\n",
    "print(\"场景1 — 编号 '2':\")\n",
    "resolve_test_files(files)\n",
    "\n",
    "# 场景2: 精确文件名（不带 .md）\n",
    "os.environ[\"TEST_INDEX\"] = \"new\"\n",
    "print(\"\\n场景2 — 文件名 'new':\")\n",
    "resolve_test_files(files)\n",
    "\n",
    "# 场景3: 精确文件名（带 .md）\n",
    "os.environ[\"TEST_INDEX\"] = \"new.md\"\n",
    "print(\"\\n场景3 — 文件名 'new.md':\")\n",
    "resolve_test_files(files)\n",
    "\n",
    "# 场景4: 模糊关键词\n",
    "os.environ[\"TEST_INDEX\"] = \"mmc3\"\n",
    "print(\"\\n场景4 — 关键词 'mmc3':\")\n",
    "resolve_test_files(files)\n",
    "\n",
    "# 场景5: 找不到\n",
    "os.environ[\"TEST_INDEX\"] = \"nonexistent\"\n",
    "print(\"\\n场景5 — 不存在:\")\n",
    "resolve_test_files(files)\n",
    "\n",
    "# 清理\n",
    "del os.environ[\"TEST_INDEX\"]"
   ]
