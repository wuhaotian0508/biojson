    "---\n",
    "## 3. `resolve_test_files()` — 测试模式文件筛选\n",
    "\n",
    "支持三种匹配方式：编号、精确文件名、模糊关键词。\n",
    "\n",
    "```python\n",
    "def resolve_test_files(files):\n",
    "    test_index = os.getenv(\"TEST_INDEX\", \"1\")\n",
    "    if test_index.isdigit():     # 纯数字 → 按编号\n",
    "        ...\n",
    "    target = test_index if test_index.endswith(\".md\") else test_index + \".md\"\n",
    "    matched = [f for f in files if f == target]   # 精确匹配\n",
    "    matched = [f for f in files if test_index in f]  # 模糊匹配\n",
    "```\n",
    "\n",
    "### 涉及的高级语法"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "sec3-syntax",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 语法1: str.isdigit() ─────────────────────────────────\n",
    "# 判断字符串是否全部由数字组成\n",
    "print(f\"'3'.isdigit()     = {'3'.isdigit()}\")\n",
    "print(f\"'42'.isdigit()    = {'42'.isdigit()}\")\n",
    "print(f\"'new'.isdigit()   = {'new'.isdigit()}\")\n",
    "print(f\"'3a'.isdigit()    = {'3a'.isdigit()}\")\n",
    "print(f\"''.isdigit()      = {''.isdigit()}\")\n",
    "\n",
    "print()\n",
    "\n",
    "# ── 语法2: str.endswith() ────────────────────────────────\n",
    "# 判断字符串是否以某后缀结尾\n",
    "fname = \"new\"\n",
    "target = fname if fname.endswith(\".md\") else fname + \".md\"\n",
    "print(f\"'{fname}' → 自动补 .md → '{target}'\")\n",
    "\n",
    "fname2 = \"new.md\"\n",
    "target2 = fname2 if fname2.endswith(\".md\") else fname2 + \".md\"\n",
    "print(f\"'{fname2}' → 已有 .md → '{target2}'\")\n",
    "\n",
    "print()\n",
    "\n",
    "# ── 语法3: 'in' 运算符在字符串上的使用 ───────────────────\n",
    "# 检查子字符串是否存在于字符串中\n",
    "filename = \"MinerU_markdown_mmc3_2031567019886178304.md\"\n",
    "print(f\"'mmc3' in '{filename}' = {'mmc3' in filename}\")\n",
    "print(f\"'xyz'  in '{filename}' = {'xyz'  in filename}\")\n",
    "\n",
    "# 列表推导中的 in 用于模糊匹配\n",
    "files = [\"aaa_mmc3_bbb.md\", \"ccc_mmc10_ddd.md\", \"new.md\"]\n",
    "keyword = \"mmc3\"\n",
    "matched = [f for f in files if keyword in f]\n",
    "print(f\"\\n模糊匹配 '{keyword}': {matched}\")"
   ]
