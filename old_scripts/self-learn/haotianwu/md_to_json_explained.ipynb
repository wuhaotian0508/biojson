    "---\n",
    "## 2. Schema → EXTRACT_TOOL — 动态构建 Function Calling 定义\n",
    "\n",
    "这是 md_to_json.py 最复杂的初始化部分：从 JSON Schema 文件动态构建 OpenAI function_calling 的 tool 定义。\n",
    "\n",
    "```python\n",
    "# 读取 schema\n",
    "paradigm = template.get(\"CropNutrientMetabolismGeneExtraction\", template)\n",
    "\n",
    "# 从 $defs 中取出基因字段定义\n",
    "gene_def = paradigm.get(\"$defs\", {}).get(\"NutrientMetabolismGene\", {})\n",
    "\n",
    "# 遍历每个字段，构建 GENE_PROPERTIES\n",
    "for field_name, field_schema in gene_def.get(\"properties\", {}).items():\n",
    "    desc = field_schema.get(\"description\", \"\")\n",
    "    if field_name in [\"Key_Intermediate_Metabolites_Affected\", \"Interacting_Proteins\"]:\n",
    "        GENE_PROPERTIES[field_name] = {\"type\": \"array\", ...}\n",
    "    else:\n",
    "        GENE_PROPERTIES[field_name] = {\"type\": \"string\", ...}\n",
    "```\n",
    "\n",
    "### 涉及的高级语法"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "sec2-syntax",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 语法1: .get() 链式取值 ───────────────────────────────\n",
    "# dict.get(key, default) 安全取值，key 不存在返回 default\n",
    "data = {\"a\": {\"b\": {\"c\": 42}}}\n",
    "print(f\"正常取值:  {data.get('a', {}).get('b', {}).get('c', 0)}\")\n",
    "print(f\"不存在时:  {data.get('x', {}).get('y', {}).get('z', 0)}\")\n",
    "# 对比直接取值（会报 KeyError）：\n",
    "# data[\"x\"][\"y\"]  → KeyError!\n",
    "\n",
    "print()\n",
    "\n",
    "# ── 语法2: .items() 遍历字典 ─────────────────────────────\n",
    "# 返回 (key, value) 元组的视图\n",
    "schema_fields = {\n",
    "    \"Gene_Name\": {\"description\": \"基因名称\"},\n",
    "    \"EC_Number\": {\"description\": \"EC 编号\"},\n",
    "}\n",
    "for field_name, field_schema in schema_fields.items():\n",
    "    print(f\"  {field_name}: {field_schema['description']}\")"
   ]
