    "---\n",
    "## 1. `stem_to_dirname()` — 文件名标准化\n",
    "\n",
    "将 MD 文件名 stem 转为 reports 子目录名（GitHub 命名规范）。\n",
    "\n",
    "```python\n",
    "def stem_to_dirname(stem):\n",
    "    if stem.startswith(\"MinerU_markdown_\"):\n",
    "        stem = stem[len(\"MinerU_markdown_\"):]  # 切掉前缀\n",
    "    stem = stem.replace(\"_(1)\", \"\")             # 去掉括号\n",
    "    stem = stem.replace(\"_\", \"-\")               # 下划线转连字符\n",
    "    return stem\n",
    "```\n",
    "\n",
    "### 涉及的高级语法"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "sec1-syntax",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 语法1: str.startswith() ──────────────────────────────\n",
    "# 判断字符串是否以某前缀开头，返回 bool\n",
    "name = \"MinerU_markdown_mmc3_2031567019886178304\"\n",
    "print(f\"startswith('MinerU_markdown_') = {name.startswith('MinerU_markdown_')}\")\n",
    "print(f\"startswith('hello')            = {name.startswith('hello')}\")\n",
    "\n",
    "# ── 语法2: len() 切片 ────────────────────────────────────\n",
    "# stem[len(prefix):]  →  从前缀结束位置开始切\n",
    "prefix = \"MinerU_markdown_\"\n",
    "print(f\"\\nlen('{prefix}') = {len(prefix)}\")\n",
    "print(f\"name[{len(prefix)}:] = '{name[len(prefix):]}'\")\n",
    "\n",
    "# 等价写法：removeprefix()（Python 3.9+）\n",
    "print(f\"removeprefix     = '{name.removeprefix(prefix)}'\")\n",
    "\n",
    "# ── 语法3: str.replace() 链式调用 ────────────────────────\n",
    "# 每次 replace 返回新字符串，可以连续调用\n",
    "raw = \"s41586-022-04950-4_(1)\"\n",
    "result = raw.replace(\"_(1)\", \"\").replace(\"_\", \"-\")\n",
    "print(f\"\\n链式 replace: '{raw}' → '{result}'\")"
   ]
  },
  {
