   "source": [
    "### 4.2 Truthy / Falsy 判断（空响应检测）\n",
    "\n",
    "```python\n",
    "has_tool_calls = message.tool_calls and len(message.tool_calls) > 0\n",
    "has_content = message.content and message.content.strip()\n",
    "if not has_tool_calls and not has_content:\n",
    "    # API 返回了空内容\n",
    "```\n",
    "\n",
    "Python 中 `None`、空字符串 `\"\"`、空列表 `[]`、`0` 都是 **falsy**。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "sec4-truthy",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Truthy / Falsy 速查 ──────────────────────────────────\n",
    "falsy_values = [None, \"\", \"   \", [], 0, False]\n",
    "for val in falsy_values:\n",
    "    # bool() 转换\n",
    "    print(f\"  bool({repr(val):>10}) = {bool(val)}\")\n",
    "\n",
    "print()\n",
    "\n",
    "# ── 短路求值（and / or）──────────────────────────────────\n",
    "# A and B：A 为 falsy 时直接返回 A，不会执行 B\n",
    "content = None\n",
    "result = content and content.strip()  # content 是 None，不会调用 .strip()\n",
    "print(f\"None and None.strip() = {result}  （不会报错！短路了）\")\n",
    "\n",
    "content = \"  hello  \"\n",
    "result = content and content.strip()  # content 有值，继续执行 .strip()\n",
    "print(f\"'  hello  ' and .strip() = '{result}'\")\n",
    "\n",
    "content = \"   \"  # 空白字符串\n",
    "result = content and content.strip()  # content 有值但 strip 后为空\n",
    "print(f\"'   ' and .strip() = '{result}'  → bool = {bool(result)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "sec4-empty-demo",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 模拟 API 空响应检测 ──────────────────────────────────\n",
    "\n",
    "class MockMessage:\n",
    "    def __init__(self, tool_calls=None, content=None):\n",
    "        self.tool_calls = tool_calls\n",
    "        self.content = content\n",
    "\n",
    "scenarios = [\n",
    "    (\"正常: 有 tool_calls\",    MockMessage(tool_calls=[\"call_1\"], content=None)),\n",
    "    (\"正常: 有 content\",       MockMessage(tool_calls=None, content=\"some text\")),\n",
    "    (\"空响应: 全 None\",        MockMessage(tool_calls=None, content=None)),\n",
    "    (\"空响应: 空列表+空字符串\", MockMessage(tool_calls=[], content=\"\")),\n",
