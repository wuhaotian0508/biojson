    "import os\n",
    "\n",
    "# ── os.path.basename() ───────────────────────────────────\n",
    "# 取路径中的文件名部分\n",
    "path = \"/data/haotianwu/biojson/md/new.md\"\n",
    "name = os.path.basename(path)\n",
    "print(f\"basename('{path}')\")\n",
    "print(f\"  → '{name}'\")\n",
    "\n",
    "# ── os.path.splitext() ───────────────────────────────────\n",
    "# 分离文件名和扩展名，返回 (stem, ext) 元组\n",
    "stem, ext = os.path.splitext(name)\n",
    "print(f\"\\nsplittext('{name}')\")\n",
    "print(f\"  → stem='{stem}', ext='{ext}'\")\n",
    "\n",
    "# 常见用法：只取 stem（去掉扩展名）\n",
    "filename = os.path.splitext(name)[0]\n",
    "print(f\"\\n[0] 取 stem: '{filename}'\")\n",
    "\n",
    "# ── os.path.join() ───────────────────────────────────────\n",
    "# 跨平台拼接路径（自动处理分隔符）\n",
    "paper_dir = os.path.join(\"/data/biojson/reports\", \"mmc3-123\")\n",
    "output_path = os.path.join(paper_dir, \"extraction.json\")\n",
    "print(f\"\\njoin: '{output_path}'\")"
   ]
